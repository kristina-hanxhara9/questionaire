# Comma-separated bearer tokens. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Multiple keys allowed for rotation.
MCP_API_KEYS=replace-with-strong-secret

# Path to your multi-sheet Excel guide (each sheet = one channel).
# If unset or missing, the bundled sample is used and a warning is logged.
EXCEL_GUIDE_PATH=

# Path to your PDF layout reference. Used to extract section structure and placeholders.
PDF_TEMPLATE_PATH=

# Path to your docxtpl Jinja2 .docx template. This is what actually gets rendered.
DOCX_TEMPLATE_PATH=

# Where rendered .docx files are written.
OUTPUT_DIR=./output

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# HTTP transport bind
HOST=0.0.0.0
PORT=8080

# Translation
TRANSLATION_TIMEOUT_S=15

# Optional OpenTelemetry endpoint (e.g. http://otel-collector:4318)
# OTEL_EXPORTER_OTLP_ENDPOINT=
